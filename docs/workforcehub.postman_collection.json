  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Once",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const token = body.accessToken || body.AccessToken || '';",
                  "const accountId = body.accountId || body.AccountId || '';",
                  "const email = body.email || body.Email || '';",
                  "if (token) pm.collectionVariables.set('jwt_token', token);",
                  "if (accountId) {",
                  "  pm.collectionVariables.set('account_id', accountId);",
                  "  pm.collectionVariables.set('employee_id', accountId);",
                  "}",
                  "if (email) pm.collectionVariables.set('email', email);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{account_command_base_url}}/api/auth/login",
              "host": [ "{{account_command_base_url}}" ],
              "path": [ "api", "auth", "login" ]
            }
          }
        }
      ]
