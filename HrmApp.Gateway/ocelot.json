        {
          "Host": "host.docker.internal",
          "Port": 5222
        }
      ],
      "UpstreamPathTemplate": "/api/accounts/{id}/password",
      "UpstreamHttpMethod": [ "PATCH" ]
    },
    {
      "DownstreamPathTemplate": "/api/accounts/{everything}",
